<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>LoginWindow</class>
 <widget class="QMainWindow" name="MainWindow_DangNhap">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Đăng nhập - Financial Architect</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: white; }
    * { font-family: 'Segoe UI', sans-serif; }
   </string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="layout_main_h">
    <property name="spacing"><number>0</number></property>
    <property name="margin"><number>0</number></property>
    <!-- PHẦN BÊN TRÁI (BRANDING) -->
    <item>
     <widget class="QFrame" name="frame_branding_left">
      <property name="styleSheet">
       <string notr="true">
        QFrame#frame_branding_left {
            background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #1E3A8A, stop:1 #1E40AF);
            border: none;
        }
        QLabel { color: white; background: transparent; }
       </string>
      </property>
      <layout class="QVBoxLayout" name="layout_branding_v">
       <property name="spacing"><number>20</number></property>
       <property name="leftMargin"><number>60</number></property>
       <property name="topMargin"><number>60</number></property>
       <property name="rightMargin"><number>60</number></property>
       <item>
        <widget class="QLabel" name="lbl_logo_app">
         <property name="text"><string>🏦 Financial Architect</string></property>
         <property name="styleSheet"><string>font-size: 20px; font-weight: bold;</string></property>
        </widget>
       </item>
       <item><spacer name="spacer_branding_top"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>100</height></size></property></spacer></item>
       <item>
        <widget class="QLabel" name="lbl_branding_headline">
         <property name="text"><string>Làm chủ tài chính&lt;br&gt;của bạn.</string></property>
         <property name="styleSheet"><string>font-size: 48px; font-weight: bold; line-height: 1.2;</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="lbl_branding_subtext">
         <property name="text"><string>Hệ thống quản lý tài chính thông minh giúp bạn hoạch định tương lai vững chắc và đạt được sự tự do tài chính.</string></property>
         <property name="wordWrap"><bool>true</bool></property>
         <property name="styleSheet"><string>font-size: 16px; color: #DBEAFE;</string></property>
        </widget>
       </item>
       <item><spacer name="spacer_branding_bottom"><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item>
      </layout>
     </widget>
    </item>
    <!-- PHẦN BÊN PHẢI (LOGIN FORM) -->
    <item>
     <widget class="QFrame" name="frame_login_right">
      <property name="styleSheet">
       <string notr="true">
        QFrame#frame_login_right { background-color: white; border: none; }
        QLabel#lbl_welcome_title { font-size: 32px; font-weight: bold; color: #1E293B; }
        QLabel#lbl_instruction_text { font-size: 14px; color: #64748B; }
        QLabel[objectName^="lbl_label_field_"] { font-weight: bold; font-size: 13px; color: #1E293B; }
        QLineEdit {
            background-color: #F1F5F9;
            border: 1px solid #E2E8F0;
            border-radius: 8px;
            padding: 12px;
            font-size: 14px;
            color: #1E293B;
        }
        QPushButton#btn_dangnhap_submit {
            background-color: #1E40AF;
            color: white;
            font-weight: bold;
            border-radius: 8px;
            padding: 12px;
            font-size: 15px;
        }
        QPushButton#btn_dangnhap_submit:hover { background-color: #1E3A8A; }
        QPushButton#btn_dangnhap_google {
            background-color: white;
            border: 1px solid #E2E8F0;
            border-radius: 8px;
            padding: 10px;
            font-weight: 500;
        }
       </string>
      </property>
      <layout class="QVBoxLayout" name="layout_login_form_v">
       <property name="leftMargin"><number>80</number></property>
       <property name="rightMargin"><number>80</number></property>
       <property name="topMargin"><number>40</number></property>
       <property name="bottomMargin"><number>40</number></property>
       <item><spacer name="spacer_form_top"><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item>
       <item>
        <widget class="QLabel" name="lbl_welcome_title">
         <property name="text"><string>Chào mừng trở lại</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="lbl_instruction_text">
         <property name="text"><string>Vui lòng đăng nhập để quản lý tài khoản của bạn.</string></property>
        </widget>
       </item>
       <item><spacer name="spacer_form_header"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>30</height></size></property></spacer></item>
       <!-- Email (NguoiDung.Email) -->
       <item><widget class="QLabel" name="lbl_label_field_email"><property name="text"><string>Email</string></property></widget></item>
       <item><widget class="QLineEdit" name="txt_nguoidung_email"><property name="placeholderText"><string>example@email.com</string></property></widget></item>
       <!-- Password (NguoiDung.MatKhauHash) -->
       <item>
        <layout class="QHBoxLayout" name="layout_pwd_label_h">
         <item><widget class="QLabel" name="lbl_label_field_password"><property name="text"><string>Mật khẩu</string></property></widget></item>
         <item><spacer name="spacer_pwd_label"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
         <item><widget class="QLabel" name="lbl_link_quen_matkhau"><property name="text"><string>&lt;a href='#' style='text-decoration:none; color:#1E40AF;'&gt;Quên mật khẩu?&lt;/a&gt;</string></property></widget></item>
        </layout>
       </item>
       <item><widget class="QLineEdit" name="txt_nguoidung_matkhau"><property name="placeholderText"><string>••••••••</string></property><property name="echoMode"><enum>QLineEdit::Password</enum></property></widget></item>
       <item><spacer name="spacer_form_fields"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>20</height></size></property></spacer></item>
       <item><widget class="QPushButton" name="btn_dangnhap_submit"><property name="text"><string>Đăng nhập</string></property></widget></item>
       <item><spacer name="spacer_form_divider"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>30</height></size></property></spacer></item>
       <item><widget class="QLabel" name="lbl_login_separator"><property name="text"><string>────────  HOẶC ĐĂNG NHẬP VỚI  ────────</string></property><property name="alignment"><enum>Qt::AlignCenter</enum></property><property name="styleSheet"><string>color: #94A3B8; font-size: 11px;</string></property></widget></item>
       <item><spacer name="spacer_form_google"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>20</height></size></property></spacer></item>
       <item><widget class="QPushButton" name="btn_dangnhap_google"><property name="text"><string>G Google</string></property></widget></item>
       <item><spacer name="spacer_form_footer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint"><size><width>20</width><height>30</height></size></property></spacer></item>
       <item><widget class="QLabel" name="lbl_link_dangky_taikhoan"><property name="text"><string>Chưa có tài khoản? &lt;a href='#' style='text-decoration:none; color:#1E40AF; font-weight:bold;'&gt;Đăng ký tài khoản mới&lt;/a&gt;</string></property><property name="alignment"><enum>Qt::AlignCenter</enum></property></widget></item>
       <item><spacer name="spacer_form_bottom"><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item>
       <!-- Bottom Links -->
       <item>
        <layout class="QHBoxLayout" name="layout_footer_links_h">
         <item><widget class="QLabel" name="lbl_footer_trogiup"><property name="text"><string>&lt;small&gt;Trợ giúp&lt;/small&gt;</string></property><property name="styleSheet"><string>color: #94A3B8;</string></property></widget></item>
         <item><widget class="QLabel" name="lbl_footer_quyenriengtu"><property name="text"><string>&lt;small&gt;Quyền riêng tư&lt;/small&gt;</string></property><property name="styleSheet"><string>color: #94A3B8;</string></property></widget></item>
         <item><spacer name="spacer_footer_links"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
         <item><widget class="QLabel" name="lbl_footer_ngonngu"><property name="text"><string>&lt;small&gt;Việt Nam (VN)&lt;/small&gt;</string></property><property name="styleSheet"><string>color: #94A3B8;</string></property></widget></item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
</ui>