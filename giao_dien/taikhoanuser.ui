   <string notr="true">
QMainWindow { background-color: #F8FAFC; font-family: 'Segoe UI', sans-serif; }
QFrame#sidebar { background-color: #F1F5F9; border-right: 1px solid #E2E8F0; }
QPushButton#sideBtn { text-align: left; padding: 12px 20px; border: none; border-radius: 8px; color: #64748B; font-size: 13px; margin: 2px 10px; }
QPushButton#sideBtn:hover { background-color: #E2E8F0; color: #1E293B; }
QPushButton#sideBtn_active { text-align: left; padding: 12px 20px; border: none; border-radius: 8px; background-color: #DBEAFE; color: #1E40AF; font-weight: bold; margin: 2px 10px; }
QFrame#whiteCard { background-color: white; border-radius: 15px; border: 1px solid #E2E8F0; }
QLineEdit, QComboBox { background-color: #F1F5FE; border: none; border-radius: 8px; padding: 12px; font-size: 14px; color: #1E293B; }
QPushButton#btnSave { background-color: #1E40AF; color: white; border-radius: 10px; font-weight: bold; padding: 15px 30px; font-size: 14px; }
QFrame#profileHeaderBlue { background-color: #1E40AF; border-top-left-radius: 15px; border-top-right-radius: 15px; }
QFrame#avatarCircle { background-color: #E2E8F0; border: 4px solid white; border-radius: 50px; }
QFrame#switchOn { background-color: #1E40AF; border-radius: 10px; min-width: 40px; max-width: 40px; min-height: 20px; }
QFrame#switchOff { background-color: #CBD5E1; border-radius: 10px; min-width: 40px; max-width: 40px; min-height: 20px; }
</string>
