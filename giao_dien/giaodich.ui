        color: #1E40AF;
        font-weight: bold;
    }
    /* Style cho bảng danh sách */
    QTableWidget#tbl_danhsach_giaodich { background-color: white; border: none; gridline-color: #F1F5F9; border-radius: 12px; }
    QHeaderView::section { background-color: #EEF2FD; padding: 10px; border: none; font-weight: bold; color: #64748B; }
